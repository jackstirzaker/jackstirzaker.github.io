{
  "private": true,
  "scripts": {
    "serve": "cross-env NODE_ENV=development concurrently \"postcss tailwind.css -o ../build/tailwind.css --watch\"  \"live-server ../\"",
    "development": "cross-env NODE_ENV=development postcss tailwind.css -o ../build/tailwind.css",
    "production": "cross-env NODE_ENV=production postcss tailwind.css -o ../build/tailwind.css",
    "start": "npm run serve"
  },
  "dependencies": {
    "@tailwindcss/ui": "^0.3.0",
    "autoprefixer": "^9.8.0",
    "tailwindcss": "^1.4.6",
    "tailwindcss-filters": "^3.0.0"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^1.2.0",
    "concurrently": "^5.2.0",
    "cross-env": "^5.2.0",
    "cssnano": "^4.1.10",
    "live-server": "^1.2.1",
    "postcss-cli": "^7.1.1"
  }
}
